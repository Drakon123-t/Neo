                <div class="vertical-card__content">
                    <div class="vertical-card__content__text">
                        <div class="content-tags content-tags--purple-gray">
                                <a class="tag" href="/whats-happening/all-news---events?topic=AI" aria-label="AI">AI</a>
                                <a class="tag" href="/whats-happening/all-news---events?topic=Explainers" aria-label="Explainers">Explainers</a>
