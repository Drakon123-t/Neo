<script>
    document.getElementById("footer_subscribeBtn").addEventListener("click", async function () {
        const email = document.getElementById("footeremailBanner").value.trim();

        const response = await fetch('/api/newsletter/subscribe', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({ email: email })
        });

        const result = await response.json();


        if (result.success === true) {
            document.getElementById('footer-email-error-banner').style.display = 'none';
            document.getElementById('footer-email-success-banner').style.display = 'inline';
        }
        else {
            document.getElementById('footer-email-success-banner').style.display = 'none';
            const errorBanner = document.getElementById('footer-email-error-banner');
            errorBanner.style.display = 'inline';
            errorBanner.textContent = result.message;

        }

    });
</script>






